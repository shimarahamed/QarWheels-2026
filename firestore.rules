/**
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model where all user-generated
 * content (profiles, cars, service records) is nested within a private data tree
 * at /users/{userId}. Access to this tree is granted only when the authenticated
 * user's ID matches the {userId} in the path, ensuring strong data isolation.
 *
 * Vendor data is owned by a specific user (ownerId), who can manage their own
 * profile and subcollections (services, inventory, etc.). Public read access to
 * vendor data is limited to approved vendors.
 *
 * Data Structure:
 * - /users/{userId}: The root for all data belonging to a single user.
 *   - /cars/{carId}: A user's vehicles.
 *     - /serviceRecords/{serviceRecordId}: Maintenance history for a specific car.
 *     - /servicePredictions/{servicePredictionId}: AI-generated maintenance predictions.
 * - /vendors/{vendorId}: A top-level collection for service vendors.
 *   - /services/{serviceId}: Services offered by the vendor.
 *   - /inventory/{itemId}: Parts and supplies inventory.
 *   - /staff/{staffId}: Staff members.
 *   - /promotions/{promotionId}: Special offers.
 *   - /reviews/{reviewId}: Customer feedback.
 * - /bookings/{bookingId}: A top-level collection for all appointments.
 * - /roles_admin/{adminId}: A collection for managing admin privileges.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --------------------------------
    // User Data Rules
    // --------------------------------

    match /users/{userId} {
      allow get, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      // Deleting user profiles is a sensitive operation, restrict to admins for now
      allow delete: if isAdmin();

      match /cars/{carId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwner(userId);

        // The serviceRecords subcollection is now secured entirely by the collectionGroup rule below
        // to prevent rule conflicts.

        match /servicePredictions/{servicePredictionId} {
          allow get, list, create, update, delete: if isOwner(userId);
        }
      }
    }
    
    // --------------------------------
    // Collection Group Rules
    // --------------------------------

    // This is the authoritative rule for ALL access to serviceRecords.
    // It secures reads and writes for both individual documents and collection-wide queries.
    match /{path=**}/serviceRecords/{serviceRecordId} {
       // A user can get a single record if their UID matches the record's userId field.
       allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
       
       // A user can query the serviceRecords collection if they are signed in.
       // This is secure because Firestore's backend enforces that any such query
       // MUST include a `where('userId', '==', request.auth.uid)` clause.
       allow list: if isSignedIn();

       // A user can create/update/delete a record if their UID matches the userId in the record's data.
       // This ensures users can only write to their own records.
       allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }


    // --------------------------------
    // Vendor Rules
    // --------------------------------
    
    function isVendorOwner(vendorId) {
      let vendorData = get(/databases/$(database)/documents/vendors/$(vendorId)).data;
      return isSignedIn() && request.auth.uid == vendorData.ownerId;
    }

    match /vendors/{vendorId} {
      // Allow any signed-in user to read/list vendor profiles that are approved.
      allow get: if isSignedIn() && resource.data.status == 'Approved';
      allow list: if isSignedIn(); // Client must filter by 'status == "Approved"'
      
      // Only signed-in users can create a vendor profile, and they must be the owner
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      // Only the vendor owner or an admin can update/delete
      allow update, delete: if isVendorOwner(vendorId) || isAdmin();

      // --- Explicit Sub-collection Rules for Stability ---
      
      match /services/{serviceId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isVendorOwner(vendorId) || isAdmin();
      }
      
      match /reviews/{reviewId} {
        allow get, list: if isSignedIn();
        // Allow any signed in user to create a review.
        allow create: if isSignedIn();
        allow update, delete: if isOwner(resource.data.userId) || isVendorOwner(vendorId) || isAdmin();
      }

      match /inventory/{itemId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isVendorOwner(vendorId) || isAdmin();
      }

      match /staff/{staffId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isVendorOwner(vendorId) || isAdmin();
      }

      match /promotions/{promotionId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isVendorOwner(vendorId) || isAdmin();
      }
    }
    
    // --------------------------------
    // Global Data Rules
    // --------------------------------

    match /bookings/{bookingId} {
      function isBookingOwner() {
        return isOwner(resource.data.userId);
      }
      
      function isBookingVendor() {
          return isSignedIn() && exists(/databases/$(database)/documents/vendors/$(resource.data.vendorId)) &&
                 get(/databases/$(database)/documents/vendors/$(resource.data.vendorId)).data.ownerId == request.auth.uid;
      }
      
      allow get: if isBookingOwner() || isBookingVendor() || isAdmin();
      allow list: if isSignedIn(); // Users can list bookings, but client must filter by userId or vendorId
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isBookingOwner() || isBookingVendor() || isAdmin();
    }

    // --------------------------------
    // Admin & Role Management Rules
    // --------------------------------

    match /roles_admin/{adminId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}
