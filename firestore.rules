/**
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model where all user-generated
 * content (profiles, cars, service records) is nested within a private data tree
 * at /users/{userId}. Access to this tree is granted only when the authenticated
 * user's ID matches the {userId} in the path, ensuring strong data isolation.
 *
 * Data Structure:
 * - /users/{userId}: The root for all data belonging to a single user.
 *   - /cars/{carId}: A user's vehicles.
 *     - /serviceRecords/{serviceRecordId}: Maintenance history for a specific car.
 *     - /servicePredictions/{servicePredictionId}: AI-generated maintenance predictions.
 * - /vendors/{vendorId}: A top-level collection for service vendors. Data is
 *   publicly readable only for vendors with a status of 'Approved'.
 * - /bookings/{bookingId}: A top-level collection for all appointments.
 * - /roles_admin/{adminId}: A collection for managing admin privileges. The existence
 *   of a document with the user's ID grants them admin access.
 *
 * Key Security Decisions:
 * - User Isolation: Users are strictly forbidden from accessing another user's data tree.
 *   User listing at the top level is disallowed.
 * - Public vs. Private Data: The /vendors collection uses a 'status' field to
 *   control public visibility. Unapproved vendors are invisible to non-admin users.
 *   This is a form of structural segregation within a single collection.
 * - Admin Access: Administrative privileges are managed by the existence of a
 *   document in the /roles_admin collection, providing a clear and simple
 *   mechanism for role-based access control.
 *
 * Denormalization for Authorization:
 * - To ensure fast and simple rules, relational data required for authorization is
 *   denormalized. For example, documents created within a user's data tree
 *   (e.g., a Car) must contain a `userId` field that matches the path. This
 *   prevents data from being misplaced and simplifies validation logic without
 *   requiring slow `get()` calls to parent documents.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Returns true if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user is an administrator by
     * verifying the existence of their UID in the /roles_admin collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * Returns true if the requesting user's UID matches the provided userId.
     * This is the core function for enforcing data ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Returns true if the document exists and the requesting user is the owner.
     * Used for safe update and delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates that the UserProfile document being created has an 'id' field
     * that matches the document's ID in the path.
     */
    function hasValidUserProfileDataOnCreate(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * Enforces immutability of the UserProfile's 'id' field during an update.
     */
    function hasValidUserProfileDataOnUpdate() {
      return request.resource.data.id == resource.data.id;
    }

    /**
     * Validates relational integrity on Car creation. Ensures the car's 'userId'
     * field matches the path parameter.
     */
    function hasValidCarDataOnCreate(userId) {
      return request.resource.data.userId == userId;
    }

    /**
     * Enforces immutability of a Car's 'id' and 'userId' fields during an update.
     */
    function hasValidCarDataOnUpdate() {
      // The 'id' field of a car document is not standard and should not be enforced.
      return request.resource.data.userId == resource.data.userId;
    }

    /**
     * Validates that a new ServiceRecord is correctly linked to its parent car.
     */
    function hasValidServiceRecordDataOnCreate(carId) {
      return request.resource.data.carId == carId;
    }

    /**
     * Enforces immutability of a ServiceRecord's parent 'carId' during an update.
     */
    function hasValidServiceRecordDataOnUpdate() {
      return request.resource.data.carId == resource.data.carId;
    }

    /**
     * Validates that a new ServicePrediction is correctly linked to its parent car.
     */
    function hasValidServicePredictionDataOnCreate(carId) {
      return request.resource.data.carId == carId;
    }

    /**
     * Enforces immutability of a ServicePrediction's parent 'carId' during an update.
     */
    function hasValidServicePredictionDataOnUpdate() {
      return request.resource.data.carId == resource.data.carId;
    }


    // --------------------------------
    // User Data Rules
    // --------------------------------

    /**
     * @description A user can create their own profile, and only they can read or modify it.
     * @path /users/{userId}
     * @allow A signed-in user (auth.uid='user_abc') can create their own profile at /users/user_abc.
     * @deny A user (auth.uid='user_abc') cannot read or write to /users/user_xyz.
     * @principle Restricts access to a user's own data tree (Self-Creation & Ownership).
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && hasValidUserProfileDataOnCreate(userId);
      allow update: if isExistingOwner(userId) && hasValidUserProfileDataOnUpdate();
      allow delete: if isExistingOwner(userId);

      /**
       * @description A user can manage the cars they own within their own profile.
       * @path /users/{userId}/cars/{carId}
       * @allow A user (auth.uid='user_abc') can create a new car document under /users/user_abc/cars/.
       * @deny A user (auth.uid='user_abc') cannot list or get cars under /users/user_xyz/cars/.
       * @principle Enforces document ownership for all operations based on the path.
       */
      match /cars/{carId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && hasValidCarDataOnCreate(userId);
        allow update: if isOwner(userId) && hasValidCarDataOnUpdate();
        allow delete: if isOwner(userId);

        /**
         * @description A user can manage service records for their own cars.
         * @path /users/{userId}/cars/{carId}/serviceRecords/{serviceRecordId}
         * @allow A user (auth.uid='user_abc') can add a service record to their own car.
         * @deny A user (auth.uid='user_abc') cannot delete a service record for another user's car.
         * @principle Access is inherited from the parent user document path.
         */
        match /serviceRecords/{serviceRecordId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && hasValidServiceRecordDataOnCreate(carId);
          allow update: if isExistingOwner(userId) && hasValidServiceRecordDataOnUpdate();
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description A user can manage service predictions for their own cars.
         * @path /users/{userId}/cars/{carId}/servicePredictions/{servicePredictionId}
         * @allow A user (auth.uid='user_abc') can read predictions generated for their car.
         * @deny An anonymous user cannot access any service predictions.
         * @principle Access is inherited from the parent user document path.
         */
        match /servicePredictions/{servicePredictionId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && hasValidServicePredictionDataOnCreate(carId);
          allow update: if isExistingOwner(userId) && hasValidServicePredictionDataOnUpdate();
          allow delete: if isExistingOwner(userId);
        }
      }
    }

    // --------------------------------
    // Global Data Rules
    // --------------------------------

    /**
     * @description Allows public read access for 'Approved' vendors. Admins can manage all vendors.
     * @path /vendors/{vendorId}
     * @allow Any user (signed-in or not) can read a vendor document if its 'status' field is 'Approved'.
     * @deny A non-admin user cannot read a vendor document if its 'status' is 'Pending Approval'.
     * @principle Manages public read access via a status field, with writes restricted to admins.
     */
    match /vendors/{vendorId} {
      allow get: if resource.data.status == 'Approved' || isAdmin();
      allow list: if true;
      // CRITICAL: Cannot implement owner-only writes. The 'Vendor' entity is missing an 'ownerId' field referenced in the app reasoning.
      allow create: if isAdmin(); // TODO: Add owner validation (e.g., isOwner(request.resource.data.ownerId)) once the schema is updated.
      allow update, delete: if isAdmin(); // TODO: Add owner validation (e.g., isOwner(resource.data.ownerId)) once the schema is updated.
    }
    
    /**
     * @description Manages access to service bookings.
     * @path /bookings/{bookingId}
     * @allow A user can create their own booking and can only view/manage bookings they own.
     * @deny A user cannot view or modify another user's bookings.
     * @principle Enforces data ownership on a global collection via a 'userId' field.
     */
    match /bookings/{bookingId} {
      allow get, list: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    // --------------------------------
    // Admin & Role Management Rules
    // --------------------------------

    /**
     * @description Restricts all access to the admin roles collection to existing admins.
     * @path /roles_admin/{adminId}
     * @allow An admin can read the list of other admins or add a new admin.
     * @deny A non-admin user cannot read, list, or write to this collection.
     * @principle Secures the role management system by ensuring only admins can manage it.
     */
    match /roles_admin/{adminId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}

    