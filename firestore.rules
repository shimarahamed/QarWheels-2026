rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    function isVendorOwner(vendorId) {
      return get(/databases/$(database)/documents/vendors/$(vendorId)).data.ownerId == request.auth.uid;
    }

    // User Profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      // Car Subcollection
      match /cars/{carId} {
        allow read, write: if isOwner(userId) || isAdmin();
        
        // Service Records
        match /serviceRecords/{recordId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
        
        // Service Predictions
        match /servicePredictions/{predictionId} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isAdmin(); // AI/System managed
        }
      }
    }

    // Collection Group rules for serviceRecords (needed for dashboard stats)
    match /{path=**}/serviceRecords/{recordId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
    }

    // Vendors
    match /vendors/{vendorId} {
      allow read: if (resource.data.status == 'Approved') || isVendorOwner(vendorId) || isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isVendorOwner(vendorId) || isAdmin();

      match /services/{serviceId} { allow read: if true; allow write: if isVendorOwner(vendorId); }
      match /inventory/{itemId} { allow read, write: if isVendorOwner(vendorId); }
      match /staff/{staffId} { allow read, write: if isVendorOwner(vendorId); }
      match /promotions/{promotionId} { allow read: if true; allow write: if isVendorOwner(vendorId); }
      match /reviews/{reviewId} { 
        allow read: if true; 
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }
    }

    // Bookings
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || 
        isVendorOwner(resource.data.vendorId) || 
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.userId) || 
        isVendorOwner(resource.data.vendorId) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Admin Roles
    match /roles_admin/{adminId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only manageable via Firebase Console/Admin SDK
    }
  }
}